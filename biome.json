{
	"$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!**/*.css"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useSemanticElements": "warn",
				"noSvgWithoutTitle": "warn"
			},
			"performance": {
				"noImgElement": "warn",
				"noAccumulatingSpread": "warn"
			},
			"suspicious": {
				"noArrayIndexKey": "warn",
				"noExplicitAny": "warn",
				"noAlert": "error"
			},
			"correctness": {
				"noUnusedFunctionParameters": "warn",
				"noUnusedVariables": "warn",
				"noUnusedImports": "warn",
				"noRestrictedElements": {
					"level": "warn",
					"options": {
						"elements": {
							"button": "use the shadcn Button from @/components/ui/button",
							"input": "use the shadcn Input from @/components/ui/input",
							"select": "use the shadcn Select",
							"textarea": "use the shadcn Textarea",
							"dialog": "use the shadcn Dialog"
						}
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"includes": ["**/components/ui/**"],
			"linter": {
				"rules": {
					"correctness": { "noRestrictedElements": "off" }
				}
			}
		}
	]
}
